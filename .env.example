# Django
DJANGO_SECRET_KEY=your-strong-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database mode: sqlite or mysql
DB_ENGINE=sqlite

# SQLite settings (used when DB_ENGINE=sqlite)
SQLITE_DB_NAME=db.sqlite3

# MySQL settings (used when DB_ENGINE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
MYSQL_DB_NAME=lanka_work_force
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=your_mysql_password
